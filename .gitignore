# 1. DATABASE FILES (Leakproof Shield)
# Prevents uploading your local database containing sensitive logs
aegisvision_production.db
*.db
*.sqlite3

# 2. HEAVY AI MODELS
# Prevents uploading massive weights that will freeze Git
best.pt
yolov8n.pt
*.pt
*.onnx

# 3. GENERATED ASSETS & EVIDENCE
# Prevents uploading local snapshots and video clips
evidence/
static/
*.mp4
*.avi

# 4. ARCHIVES
aegis-vision.zip
*.zip
*.tar.gz

# 5. PYTHON & MAC SYSTEM CACHE
__pycache__/
*.pyc
.DS_Store
.env